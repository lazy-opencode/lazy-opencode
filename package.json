{
  "name": "lazy-opencode",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "build:test": "node --test scripts/build-artifacts.test.mjs",
    "api:test": "tsc -p scripts/tsconfig.api-tests.json",
    "pack:test": "pnpm build && node --test scripts/pack-consumer.test.mjs",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:run": "turbo test:run",
    "coverage": "turbo coverage",
    "lint": "turbo lint",
    "format": "turbo format && oxfmt scripts .github package.json turbo.json pnpm-workspace.yaml",
    "format:check": "turbo format:check && oxfmt scripts .github package.json turbo.json pnpm-workspace.yaml --check",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:run && pnpm build && pnpm build:test && pnpm api:test",
    "npm-publish:test": "node --test scripts/publish-workspaces.test.mjs && pnpm pack:test",
    "npm-publish:dry-run": "node scripts/publish-workspaces.mjs --dry-run",
    "npm-publish:publish": "node scripts/publish-workspaces.mjs --publish",
    "release:test": "pnpm npm-publish:test",
    "release:dry-run": "pnpm npm-publish:dry-run",
    "release:publish": "pnpm npm-publish:publish",
    "clean": "pnpm -r --sort --if-present clean"
  },
  "devDependencies": {
    "@rslib/core": "^0.23.1",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.10.0",
    "typescript": "7.0.1-rc",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0"
}
