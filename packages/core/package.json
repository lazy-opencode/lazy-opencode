{
  "name": "@lazy-opencode/core",
  "version": "0.0.0",
  "private": false,
  "description": "Shared helpers for composing lazy opencode plugins.",
  "keywords": [
    "agent",
    "automation",
    "opencode",
    "plugin"
  ],
  "homepage": "https://github.com/lazy-opencode/lazy-opencode#readme",
  "bugs": {
    "url": "https://github.com/lazy-opencode/lazy-opencode/issues"
  },
  "license": "MIT",
  "author": "mouyase",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lazy-opencode/lazy-opencode.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "rslib",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint --type-aware . -f agent",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  }
}
